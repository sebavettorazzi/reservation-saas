generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessCategory {
  GENERAL
  SALON
  SPORTS
  DENTAL
  BEAUTY
}

enum SubscriptionPlan {
  BASE
  PREMIUM
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum NotificationChannel {
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SIMULATED
  SENT
  FAILED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())

  businesses Business[]
  sessions   Session[]
}

model Business {
  id          String           @id @default(uuid())
  name        String
  slug        String?          @unique
  category    BusinessCategory @default(GENERAL)
  plan        SubscriptionPlan @default(BASE)
  tagline     String?
  description String?
  ownerId     String
  createdAt   DateTime         @default(now())

  owner      User        @relation(fields: [ownerId], references: [id])
  services   Service[]
  staff      Staff[]
  customers  Customer[]
  appointments Appointment[]
  expenses   Expense[]
  notifications Notification[]

  @@unique([name, ownerId])
}

model Staff {
  id         String   @id @default(uuid())
  name       String
  businessId String

  business     Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]
  schedules    CourtSchedule[]

  services StaffService[]
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  duration    Int
  price       Float
  businessId  String

  business     Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]

  staff StaffService[]

  @@unique([name, businessId])
}

model Customer {
  id         String   @id @default(uuid())
  name       String
  email      String?
  phone      String?
  businessId String

  business     Business      @relation(fields: [businessId], references: [id])
  appointments Appointment[]

  @@unique([email, businessId])
}

model Appointment {
  id         String   @id @default(uuid())
  businessId String
  serviceId  String
  customerId String
  staffId    String?

  startTime  DateTime
  endTime    DateTime
  status        AppointmentStatus @default(PENDING)
  priceSnapshot Float
  confirmationToken String? @unique
  confirmationExpiresAt DateTime?

  business Business @relation(fields: [businessId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  staff    Staff?   @relation(fields: [staffId], references: [id])
  notifications Notification[]

  @@index([businessId, startTime])
  @@index([staffId, startTime, endTime])
}

model Expense {
  id          String   @id @default(uuid())
  businessId  String
  title       String
  category    String?
  amount      Float
  notes       String?
  expenseDate DateTime
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@index([businessId, expenseDate])
}

model StaffService {
  staffId   String
  serviceId String

  staff     Staff   @relation(fields: [staffId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@id([staffId, serviceId])
}

model CourtSchedule {
  id           String  @id @default(uuid())
  staffId      String
  weekday      Int
  startMinute  Int     @default(420)
  endMinute    Int     @default(1320)
  slotInterval Int     @default(30)
  isOpen       Boolean @default(true)

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, weekday])
  @@index([staffId, weekday])
}

model Session {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Notification {
  id            String             @id @default(uuid())
  businessId    String
  appointmentId String?
  channel       NotificationChannel @default(WHATSAPP)
  recipient     String
  body          String
  status        NotificationStatus @default(PENDING)
  scheduledAt   DateTime           @default(now())
  sentAt        DateTime?
  createdAt     DateTime           @default(now())

  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([businessId, status, scheduledAt])
  @@index([appointmentId])
}
